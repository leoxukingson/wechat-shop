<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>精选好物 - 微信直购</title>
    <style>
        /* 重置样式 */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #f5f5f5;
            color: #333;
            line-height: 1.6;
        }
        
        /* 容器 */
        .container {
            max-width: 100%;
            background: white;
            min-height: 100vh;
        }
        
        /* 头部 */
        .header {
            background: #07c160;
            color: white;
            padding: 20px 15px;
            text-align: center;
        }
        
        .logo {
            font-size: 24px;
            font-weight: bold;
            margin-bottom: 5px;
        }
        
        .slogan {
            font-size: 14px;
            opacity: 0.9;
        }
        
        /* 产品列表 */
        .products {
            padding: 15px;
        }
        
        .product-card {
            background: white;
            border-radius: 10px;
            overflow: hidden;
            margin-bottom: 15px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            border: 1px solid #eee;
        }
        
        .product-image {
            width: 100%;
            height: 180px;
            background: #f8f8f8;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #666;
            font-size: 48px;
        }
        
        .product-info {
            padding: 15px;
        }
        
        .product-title {
            font-size: 16px;
            font-weight: bold;
            margin-bottom: 8px;
            color: #333;
        }
        
        .product-desc {
            font-size: 14px;
            color: #666;
            margin-bottom: 10px;
        }
        
        .product-price {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-top: 15px;
        }
        
        .price-current {
            font-size: 18px;
            font-weight: bold;
            color: #e4393c;
        }
        
        .price-original {
            font-size: 14px;
            color: #999;
            text-decoration: line-through;
            margin-left: 5px;
        }
        
        .btn-buy {
            background: #07c160;
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 20px;
            font-size: 14px;
            font-weight: bold;
            cursor: pointer;
        }
        
        .btn-buy:active {
            background: #05a049;
            transform: scale(0.98);
        }
        
        /* 底部导航 */
        .footer {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: white;
            border-top: 1px solid #eee;
            display: flex;
            padding: 10px 0;
        }
        
        .footer-item {
            flex: 1;
            text-align: center;
            color: #666;
            font-size: 12px;
        }
        
        .footer-icon {
            font-size: 20px;
            margin-bottom: 3px;
        }
        
        .footer-item.active {
            color: #07c160;
        }
        
        /* 购物车按钮 */
        .cart-btn {
            position: fixed;
            bottom: 70px;
            right: 20px;
            width: 50px;
            height: 50px;
            background: #07c160;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 24px;
            box-shadow: 0 4px 12px rgba(7, 193, 96, 0.3);
            cursor: pointer;
        }
        
        .cart-count {
            position: absolute;
            top: -5px;
            right: -5px;
            background: #e4393c;
            color: white;
            font-size: 12px;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- 头部 -->
        <div class="header">
            <div class="logo">🛒 精选好物</div>
            <div class="slogan">微信直购 · 正品保障</div>
        </div>
        
        <!-- 产品列表 -->
        <div class="products">
            <!-- 产品1 -->
            <div class="product-card">
                <div class="product-image">🩲</div>
                <div class="product-info">
                    <div class="product-title">朵蕾蜜天鹅奢绒卫生巾</div>
                    <div class="product-desc">8片装，超薄透气，棉柔表层，舒适亲肤</div>
                    <div class="product-price">
                        <div>
                            <span class="price-current">¥26</span>
                            <span class="price-original">¥32</span>
                        </div>
                        <button class="btn-buy" onclick="addToCart(1)">立即购买</button>
                    </div>
                </div>
            </div>
            
            <!-- 产品2 -->
            <div class="product-card">
                <div class="product-image">💧</div>
                <div class="product-info">
                    <div class="product-title">渡美精华保湿水 20ML</div>
                    <div class="product-desc">日本原装，试用装，保湿滋润，适合所有肤质</div>
                    <div class="product-price">
                        <div>
                            <span class="price-current">¥42</span>
                            <span class="price-original">¥50</span>
                        </div>
                        <button class="btn-buy" onclick="addToCart(2)">立即购买</button>
                    </div>
                </div>
            </div>
            
            <!-- 产品3 -->
            <div class="product-card">
                <div class="product-image">💊</div>
                <div class="product-info">
                    <div class="product-title">双心®辅酶Q10软胶囊</div>
                    <div class="product-desc">60粒，德国进口，呵护心脏健康，增强免疫力</div>
                    <div class="product-price">
                        <div>
                            <span class="price-current">¥135</span>
                            <span class="price-original">¥168</span>
                        </div>
                        <button class="btn-buy" onclick="addToCart(3)">立即购买</button>
                    </div>
                </div>
            </div>
            
            <!-- 产品4 -->
            <div class="product-card">
                <div class="product-image">✨</div>
                <div class="product-info">
                    <div class="product-title">双心®PQQ胶原蛋白多肽</div>
                    <div class="product-desc">10支，抗衰老，美容养颜，改善皮肤弹性</div>
                    <div class="product-price">
                        <div>
                            <span class="price-current">¥380</span>
                            <span class="price-original">¥450</span>
                        </div>
                        <button class="btn-buy" onclick="addToCart(4)">立即购买</button>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- 购物车按钮 -->
        <div class="cart-btn" onclick="showCart()">
            🛒
            <div class="cart-count" id="cartCount">0</div>
        </div>
    </div>
    
    <!-- 底部导航 -->
    <div class="footer">
        <div class="footer-item active">
            <div class="footer-icon">🏠</div>
            <div>首页</div>
        </div>
        <div class="footer-item" onclick="showCategory('health')">
            <div class="footer-icon">💊</div>
            <div>保健品</div>
        </div>
        <div class="footer-item" onclick="showCategory('skincare')">
            <div class="footer-icon">💆</div>
            <div>护肤品</div>
        </div>
        <div class="footer-item" onclick="showProfile()">
            <div class="footer-icon">👤</div>
            <div>我的</div>
        </div>
    </div>
    
    <script>
        // 购物车数据
        let cart = [];
        
        // 添加到购物车
        function addToCart(productId) {
            let productName = '';
            let price = 0;
            
            // 根据产品ID获取信息
            switch(productId) {
                case 1:
                    productName = '朵蕾蜜卫生巾';
                    price = 26;
                    break;
                case 2:
                    productName = '渡美保湿水';
                    price = 42;
                    break;
                case 3:
                    productName = '双心辅酶Q10';
                    price = 135;
                    break;
                case 4:
                    productName = '双心PQQ胶原蛋白';
                    price = 380;
                    break;
            }
            
            // 添加到购物车
            cart.push({
                id: productId,
                name: productName,
                price: price
            });
            
            // 更新购物车数量
            updateCartCount();
            
            // 显示提示
            alert('已添加到购物车：' + productName + '\n价格：¥' + price);
        }
        
        // 更新购物车数量
        function updateCartCount() {
            document.getElementById('cartCount').textContent = cart.length;
        }
        
        // 显示购物车
        function showCart() {
            if (cart.length === 0) {
                alert('购物车是空的');
                return;
            }
            
            let message = '🛒 购物车内容：\n\n';
            let total = 0;
            
            cart.forEach(item => {
                message += item.name + ' - ¥' + item.price + '\n';
                total += item.price;
            });
            
            message += '\n总计：¥' + total + '\n\n';
            
            if (confirm(message + '是否前往结算？')) {
                checkout();
            }
        }
        
        // 结算
        function checkout() {
            let total = cart.reduce((sum, item) => sum + item.price, 0);
            
            // 显示支付页面
            let paymentWindow = window.open('', '支付', 'width=400,height=500');
            paymentWindow.document.write(`
                <html>
                <head>
                    <title>微信支付</title>
                    <style>
                        body { font-family: sans-serif; padding: 20px; text-align: center; }
                        .amount { font-size: 32px; color: #e4393c; margin: 20px 0; }
                        .qr { width: 200px; height: 200px; background: #f0f0f0; margin: 20px auto; display: flex; align-items: center; justify-content: center; }
                        .btn { background: #07c160; color: white; border: none; padding: 12px 30px; border-radius: 5px; font-size: 16px; cursor: pointer; margin-top: 20px; }
                    </style>
                </head>
                <body>
                    <h2>微信支付</h2>
                    <div class="amount">¥${total}</div>
                    <div class="qr">
                        支付二维码<br>(测试版)
                    </div>
                    <p>请使用微信扫描二维码</p>
                    <button class="btn" onclick="window.close(); window.opener.paymentSuccess()">模拟支付成功</button>
                </body>
                </html>
            `);
        }
        
        // 支付成功
        function paymentSuccess() {
            alert('🎉 支付成功！\n\n订单已确认，我们将尽快发货。\n\n感谢您的购买！');
            cart = [];
            updateCartCount();
        }
        
        // 显示分类（简化版）
        function showCategory(category) {
            alert('分类：' + category + '\n\n完整分类功能正在开发中...');
        }
        
        // 显示个人中心
        function showProfile() {
            alert('个人中心\n\n功能正在开发中...');
        }
        
        // 页面加载完成
        window.onload = function() {
            console.log('电商页面加载完成');
            updateCartCount();
        }
    </script>
</body>
</html>